# Multi-Provider Environment Configuration Template
# Copy this to .env and fill in your values

# ============================================================================
# PROVIDER CREDENTIALS
# ============================================================================

# ARK Provider (Production)
# Get these from ARK platform: https://ark.mckinsey.com
ARK_AIGW_UUID="your-ark-aigw-uuid-here"
ARK_DAILY_API_TOKEN="your-ark-daily-api-token-here"

# LegacyX Provider (Optional - for migration testing)
LX_AIGW_UUID="your-legacyx-aigw-uuid-here"
LX_DAILY_API_TOKEN="your-legacyx-daily-api-token-here"

# ============================================================================
# ACTIVE PROVIDER SELECTION
# ============================================================================
# Set these to point to your chosen provider (ARK or LegacyX)

# For ARK (recommended):
API_TOKEN=$ARK_DAILY_API_TOKEN
AIGW_UUID=$ARK_AIGW_UUID

# Or for LegacyX:
# API_TOKEN=$LX_DAILY_API_TOKEN
# AIGW_UUID=$LX_AIGW_UUID

# ============================================================================
# API GATEWAY CONFIGURATION
# ============================================================================

# API Gateway Base URLs
AIGW_BASE_URL="https://api.daily.co/v1"
AIGW_AGENT_BASE_URL="https://api.daily.co/v1/agents"

# Azure OpenAI Configuration (if using Azure backend)
AZURE_OPENAI_ENDPOINT="https://your-azure-endpoint.openai.azure.com/"
AZURE_API_VERSION="2024-04-01-preview"
AZURE_API_KEY="your-azure-api-key-here"

# ============================================================================
# MCP SERVER CONFIGURATION
# ============================================================================

# Perplexity API (for web research)
PERPLEXITY_API_KEY="your-perplexity-api-key-here"
PERPLEXITY_MODEL="sonar-pro"

# Google API (for web searches)
GOOGLE_API_KEY="your-google-api-key-here"
GOOGLE_CSE_ID="your-custom-search-engine-id-here"

# ============================================================================
# WORKFLOW CONFIGURATION
# ============================================================================

# Default execution mode for workflows
# Options: sequential, parallel, fake
DEFAULT_EXECUTION_MODE="sequential"

# Data file paths (relative to mcp-filesystem mount)
INPUT_DATA_PATH="/mnt/output/source_code_files/2-customer-due-diligence/input"
OUTPUT_DATA_PATH="/mnt/output/source_code_files/2-customer-due-diligence/output"

# ============================================================================
# KUBERNETES CONFIGURATION
# ============================================================================

# Namespace for KYC bundle deployment (agents, teams)
K8S_NAMESPACE="kyc-onboarding-demo"

# Namespace where MCP servers are deployed (for cross-namespace tool references)
# Default: default (shared MCP servers)
MCP_NAMESPACE="default"

# Secret name for API Gateway credentials
AIGW_SECRET_NAME="aigw-secret"

# ============================================================================
# LOGGING & DEBUGGING
# ============================================================================

# Log level for MCP servers
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL="INFO"

# Enable debug mode for workflows
DEBUG_MODE="false"

# ============================================================================
# NOTES
# ============================================================================
#
# 1. Multi-Provider Setup:
#    - Configure both ARK and LegacyX credentials
#    - Switch providers by changing API_TOKEN and AIGW_UUID assignments
#    - Run ./scripts/sync-env.sh after changes
#
# 2. Required Credentials:
#    - API_TOKEN: Daily.co API token (from ARK or LegacyX)
#    - AIGW_UUID: API Gateway workspace UUID
#    - PERPLEXITY_API_KEY: For web research (adverse media screening)
#
# 3. Optional Credentials:
#    - AZURE_*: If using Azure OpenAI backend
#    - GOOGLE_*: For Google Custom Search (alternative to Perplexity)
#
# 4. Environment Sync:
#    After updating this file, run:
#    $ source .env
#    $ cd scripts && ./sync-env.sh
#
# 5. Validation:
#    The sync-env.sh script will:
#    - Validate required variables (API_TOKEN, AIGW_UUID)
#    - Show active provider (ARK or LegacyX)
#    - Update Kubernetes secret
#    - Restart MCP server deployments
#
# ============================================================================
