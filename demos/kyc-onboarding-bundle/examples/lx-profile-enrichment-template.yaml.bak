apiVersion: argoproj.io/v1alpha1
kind: WorkflowTemplate
metadata:
  name: lx-profile-enrichment
  namespace: default
  annotations:
    workflows.argoproj.io/title: "Phase I - Customer Profile Initialization - 2a. Profile Enrichment"
    workflows.argoproj.io/description: "Collect web and government data for customer profile"
    workflows.argoproj.io/version: "v0.0.1"
spec:
  entrypoint: main
  serviceAccountName: argo-workflow
  arguments:
    parameters:
      - name: execution-mode
        value: "sequential"
        enum: ["sequential", "parallel"]
      - name: company-name
        value: "ASSOCIATED BRITISH FOODS PLC"
      - name: company-number
        value: "00293262"
      - name: web-prompts-file
        value: "source_code_files/1-customer-profile-initialization/input/prompts_web_data.yml"
      - name: gov-prompts-file
        value: "source_code_files/1-customer-profile-initialization/input/prompts_uk_gov.yml"
      - name: output-dir
        value: "source_code_files/1-customer-profile-initialization/intermediate"

  volumes:
    - name: mcp-filesystem-volume
      hostPath:
        path: /mnt/output
        type: DirectoryOrCreate

  templates:
    # ============================================================
    # Main workflow
    # ============================================================
    - name: main
      steps:
        # Step 1: Get current date
        - - name: get-current-date
            template: get-current-date-script
        
        # Step 2: Get web research prompts
        - - name: get-web-prompts
            template: get-web-prompts-script
        
        # Step 3: Collect web data (sequential or parallel based on execution-mode)
        - - name: collect-web-data-sequential
            when: "{{workflow.parameters.execution-mode}} == sequential"
            template: collect-web-data-sequential
            arguments:
              parameters:
                - name: prompts-json
                  value: "{{steps.get-web-prompts.outputs.result}}"
          
          - name: collect-web-data-parallel
            when: "{{workflow.parameters.execution-mode}} == parallel"
            template: collect-web-data-parallel
            arguments:
              parameters:
                - name: prompts-json
                  value: "{{steps.get-web-prompts.outputs.result}}"
        
        # Step 4: Get government data prompts
        - - name: get-gov-prompts
            template: get-gov-prompts-script
        
        # Step 5: Collect government data (sequential or parallel)
        - - name: collect-gov-data-sequential
            when: "{{workflow.parameters.execution-mode}} == sequential"
            template: collect-gov-data-sequential
            arguments:
              parameters:
                - name: prompts-json
                  value: "{{steps.get-gov-prompts.outputs.result}}"
          
          - name: collect-gov-data-parallel
            when: "{{workflow.parameters.execution-mode}} == parallel"
            template: collect-gov-data-parallel
            arguments:
              parameters:
                - name: prompts-json
                  value: "{{steps.get-gov-prompts.outputs.result}}"

    # ============================================================
    # Get current date
    # ============================================================
    - name: get-current-date-script
      script:
        image: alpine:3.19
        command: [sh]
        source: |
          date +"%Y-%m-%d"
      outputs:
        parameters:
          - name: result
            valueFrom:
              path: /dev/stdout

    # ============================================================
    # Get web research prompts from YAML file
    # ============================================================
    - name: get-web-prompts-script
      script:
        image: alpine:3.19
        command: [sh]
        volumeMounts:
          - name: mcp-filesystem-volume
            mountPath: /mnt/output
        source: |
          #!/bin/sh
          # Hardcoded web research prompts
          cat <<'EOF'
          [
            "Identify the official main website of the company",
            "Find the latest global employee numbers and regional distribution",
            "Provide a 4-5 sentence summary of the company's industry and market positioning",
            "Identify the company's geographic presence and operational regions",
            "Find information about the company's products and services"
          ]
          EOF
      outputs:
        parameters:
          - name: result
            valueFrom:
              path: /dev/stdout

    # ============================================================
    # Get government data prompts from YAML file
    # ============================================================
    - name: get-gov-prompts-script
      script:
        image: alpine:3.19
        command: [sh]
        volumeMounts:
          - name: mcp-filesystem-volume
            mountPath: /mnt/output
        source: |
          #!/bin/sh
          # Hardcoded government API prompts
          cat <<'EOF'
          [
            "Get company registration details from Companies House",
            "Get list of active directors and officers",
            "Get current filing status and compliance history"
          ]
          EOF
      outputs:
        parameters:
          - name: result
            valueFrom:
              path: /dev/stdout

    # ============================================================
    # Collect web data - Sequential
    # ============================================================
    - name: collect-web-data-sequential
      inputs:
        parameters:
          - name: prompts-json
      script:
        image: alpine/k8s:1.28.13
        command: [sh]
        source: |
          set -eux
          
          PROMPTS='{{inputs.parameters.prompts-json}}'
          COMPANY_NAME="{{workflow.parameters.company-name}}"
          OUTPUT_DIR="{{workflow.parameters.output-dir}}"
          CURRENT_DATE="{{steps.get-current-date.outputs.result}}"
          
          echo "$PROMPTS" | jq -r '.[]' | while IFS= read -r prompt; do
            QUERY_NAME="web-data-$(date +%s%N)"
            
            cat > /tmp/query.yaml <<EOF
          apiVersion: ark.mckinsey.com/v1alpha1
          kind: Query
          metadata:
            name: $QUERY_NAME
          spec:
            target:
              type: agent
              name: web-researcher-agent
            input: |
              Current date: $CURRENT_DATE
              Company: $COMPANY_NAME
              
              Research task: $prompt
              
              After collecting the information, save it to a JSON file using the 'mcp-filesystem-write-file' tool.
              
              Calculate the hash of the prompt and use it as the filename.
              Save to: /mnt/output/$OUTPUT_DIR/web_[hash].json
              
              JSON structure:
              {
                "company_name": "$COMPANY_NAME",
                "research_topic": "$prompt",
                "findings": "Your research findings here",
                "sources": ["source1", "source2"],
                "date": "$CURRENT_DATE"
              }
            timeout: 5m
          EOF
            
            kubectl apply -n default -f /tmp/query.yaml
            kubectl wait --for=condition=Completed --timeout=5m -n default query/$QUERY_NAME || true
          done

    # ============================================================
    # Collect web data - Parallel
    # ============================================================
    - name: collect-web-data-parallel
      inputs:
        parameters:
          - name: prompts-json
      steps:
        - - name: process-web-prompt
            template: web-data-query
            arguments:
              parameters:
                - name: prompt
                  value: "{{item}}"
            withParam: "{{inputs.parameters.prompts-json}}"

    - name: web-data-query
      inputs:
        parameters:
          - name: prompt
      resource:
        action: create
        successCondition: status.phase == done
        failureCondition: status.phase == error
        manifest: |
          apiVersion: ark.mckinsey.com/v1alpha1
          kind: Query
          metadata:
            generateName: web-data-
          spec:
            target:
              type: agent
              name: web-researcher-agent
            input: |
              Current date: {{steps.get-current-date.outputs.result}}
              Company: {{workflow.parameters.company-name}}
              
              Research task: {{inputs.parameters.prompt}}
              
              After collecting the information, save it to a JSON file using the 'mcp-filesystem-write-file' tool.
              
              Calculate the hash of the prompt and use it as the filename.
              Save to: /mnt/output/{{workflow.parameters.output-dir}}/web_[hash].json
              
              JSON structure:
              {
                "company_name": "{{workflow.parameters.company-name}}",
                "research_topic": "{{inputs.parameters.prompt}}",
                "findings": "Your research findings here",
                "sources": ["source1", "source2"],
                "date": "{{steps.get-current-date.outputs.result}}"
              }
            timeout: 5m

    # ============================================================
    # Collect government data - Sequential
    # ============================================================
    - name: collect-gov-data-sequential
      inputs:
        parameters:
          - name: prompts-json
      script:
        image: alpine/k8s:1.28.13
        command: [sh]
        source: |
          set -eux
          
          PROMPTS='{{inputs.parameters.prompts-json}}'
          COMPANY_NUMBER="{{workflow.parameters.company-number}}"
          OUTPUT_DIR="{{workflow.parameters.output-dir}}"
          CURRENT_DATE="{{steps.get-current-date.outputs.result}}"
          
          echo "$PROMPTS" | jq -r '.[]' | while IFS= read -r prompt; do
            QUERY_NAME="gov-data-$(date +%s%N)"
            
            cat > /tmp/query.yaml <<EOF
          apiVersion: ark.mckinsey.com/v1alpha1
          kind: Query
          metadata:
            name: $QUERY_NAME
          spec:
            target:
              type: agent
              name: ch-api-agent
            input: |
              Current date: $CURRENT_DATE
              Company number: $COMPANY_NUMBER
              
              Task: $prompt
              
              Use Companies House API tools to retrieve the information.
              Save the data to a JSON file using the 'mcp-filesystem-write-file' tool.
              
              Calculate the hash of the prompt and use it as the filename.
              Save to: /mnt/output/$OUTPUT_DIR/gov_[hash].json
              
              JSON structure should include all relevant fields from the API response.
            timeout: 3m
          EOF
            
            kubectl apply -n default -f /tmp/query.yaml
            kubectl wait --for=condition=Completed --timeout=3m -n default query/$QUERY_NAME || true
          done

    # ============================================================
    # Collect government data - Parallel
    # ============================================================
    - name: collect-gov-data-parallel
      inputs:
        parameters:
          - name: prompts-json
      steps:
        - - name: process-gov-prompt
            template: gov-data-query
            arguments:
              parameters:
                - name: prompt
                  value: "{{item}}"
            withParam: "{{inputs.parameters.prompts-json}}"

    - name: gov-data-query
      inputs:
        parameters:
          - name: prompt
      resource:
        action: create
        successCondition: status.phase == done
        failureCondition: status.phase == error
        manifest: |
          apiVersion: ark.mckinsey.com/v1alpha1
          kind: Query
          metadata:
            generateName: gov-data-
          spec:
            target:
              type: agent
              name: ch-api-agent
            input: |
              Current date: {{steps.get-current-date.outputs.result}}
              Company number: {{workflow.parameters.company-number}}
              
              Task: {{inputs.parameters.prompt}}
              
              Use Companies House API tools to retrieve the information.
              Save the data to a JSON file using the 'mcp-filesystem-write-file' tool.
              
              Calculate the hash of the prompt and use it as the filename.
              Save to: /mnt/output/{{workflow.parameters.output-dir}}/gov_[hash].json
              
              JSON structure should include all relevant fields from the API response.
            timeout: 3m
